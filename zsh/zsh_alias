function git_clean_gone () {
	git fetch --all -p

	local branches=()
	local worktrees=()
	local wt_count=0

	while read -r branch; do
		branches+=("$branch")
		worktree=$(git worktree list --porcelain | grep -B2 "^branch refs/heads/${branch}$" | grep "^worktree " | sed 's/^worktree //')
		if [ -n "$worktree" ]; then
			worktrees+=("$worktree")
			wt_count=$((wt_count + 1))
			echo "  $branch  [worktree: $worktree — will be removed]"
		else
			worktrees+=("")
			echo "  $branch"
		fi
	done < <(git branch -vv | grep --color=never ": gone]" | awk '{ print ($1 == "+" || $1 == "*" ? $2 : $1) }')

	if [ ${#branches[@]} -eq 0 ]; then
		echo "Nothing to clean up."
		return 0
	fi

	echo ""
	echo "Will delete ${#branches[@]} branch(es) and $wt_count worktree(s)."
	echo ""
	echo -n "Proceed? [y/N] "
	read -r confirm
	if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
		echo "Aborted."
		return 0
	fi

	echo ""
	for i in $(seq 1 ${#branches[@]}); do
		if [ -n "${worktrees[$i]}" ]; then
			echo "Removing worktree for '${branches[$i]}' at ${worktrees[$i]}"
			git worktree remove --force "${worktrees[$i]}"
		fi
		echo "Removing branch ${branches[$i]}"
		git branch -D "${branches[$i]}"
	done

	echo ""
	echo "Done. Removed $wt_count worktree(s) and ${#branches[@]} branch(es)."
}

function git_clean_wt_nochange () {
	local worktree_paths=()
	local worktree_branches=()
	local current_dir=$(pwd)

	while IFS= read -r line; do
		if [[ "$line" == worktree\ * ]]; then
			wt_path="${line#worktree }"
		elif [[ "$line" == "branch "* ]]; then
			wt_branch="${line#branch refs/heads/}"
		elif [[ -z "$line" ]]; then
			# skip the main worktree (first entry has no branch or is the main one)
			if [ -n "$wt_path" ] && [ -n "$wt_branch" ]; then
				# check if worktree has no uncommitted changes and no unpushed commits
				if git -C "$wt_path" diff --quiet 2>/dev/null && \
				   git -C "$wt_path" diff --cached --quiet 2>/dev/null && \
				   [ -z "$(git -C "$wt_path" ls-files --others --exclude-standard 2>/dev/null)" ]; then
					# check for unpushed commits
					local upstream=$(git -C "$wt_path" rev-parse --abbrev-ref "${wt_branch}@{upstream}" 2>/dev/null)
					if [ -n "$upstream" ]; then
						local ahead=$(git -C "$wt_path" rev-list --count "${upstream}..${wt_branch}" 2>/dev/null)
						if [ "$ahead" -eq 0 ] 2>/dev/null; then
							worktree_paths+=("$wt_path")
							worktree_branches+=("$wt_branch")
						fi
					else
						# no upstream — check if branch is merged into HEAD of main worktree
						if git merge-base --is-ancestor "$wt_branch" HEAD 2>/dev/null; then
							worktree_paths+=("$wt_path")
							worktree_branches+=("$wt_branch")
						fi
					fi
				fi
			fi
			wt_path=""
			wt_branch=""
		fi
	done < <(git worktree list --porcelain; echo "")

	if [ ${#worktree_paths[@]} -eq 0 ]; then
		echo "No worktrees to clean up."
		return 0
	fi

	echo "The following worktrees have no uncommitted changes and no unpushed commits:"
	echo ""
	for i in $(seq 1 ${#worktree_paths[@]}); do
		echo "  ${worktree_branches[$i]}  [${worktree_paths[$i]}]"
	done

	echo ""
	echo "Will remove ${#worktree_paths[@]} worktree(s) and delete their branches."
	echo ""
	echo -n "Proceed? [y/N] "
	read -r confirm
	if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
		echo "Aborted."
		return 0
	fi

	echo ""
	for i in $(seq 1 ${#worktree_paths[@]}); do
		echo "Removing worktree '${worktree_branches[$i]}' at ${worktree_paths[$i]}"
		git worktree remove --force "${worktree_paths[$i]}"
		git branch -D "${worktree_branches[$i]}" 2>/dev/null
	done

	echo ""
	echo "Done. Removed ${#worktree_paths[@]} worktree(s)."
}

function android_clean () {
	local dirs=()

	while IFS= read -r dir; do
		dirs+=("$dir")
	done < <(find . -type d \( -name "build" -o -name ".gradle" -o -name ".cxx" \) -not -path "./.git/*" 2>/dev/null)

	if [ ${#dirs[@]} -eq 0 ]; then
		echo "Nothing to clean up."
		return 0
	fi

	echo "Found ${#dirs[@]} build directories:"
	echo ""
	for dir in "${dirs[@]}"; do
		local size=$(du -sh "$dir" 2>/dev/null | awk '{ print $1 }')
		echo "  $dir  ($size)"
	done

	local total_kb=$(du -sc "${dirs[@]}" 2>/dev/null | tail -1 | awk '{ print $1 }')
	local total_human=$(echo "$total_kb" | awk '{
		if ($1 >= 1048576) printf "%.1fG", $1/1048576
		else if ($1 >= 1024) printf "%.1fM", $1/1024
		else printf "%dK", $1
	}')

	echo ""
	echo "Total: $total_human"
	echo ""
	echo -n "Delete all? [y/N] "
	read -r confirm
	if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
		echo "Aborted."
		return 0
	fi

	for dir in "${dirs[@]}"; do
		rm -rf "$dir"
	done

	echo "Done. Removed ${#dirs[@]} directories."
}

function gwc() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: gwc <branch>"
        return 1
    fi

    local branch="$1"

    # Find main repo root (works from any worktree)
    local main_repo
    main_repo=$(git worktree list --porcelain | awk '/^worktree / { print $2; exit }') || return 1
    local current_folder="${main_repo:t}"
    local worktree_folder="${main_repo:h}/$current_folder.worktrees/$branch"

    # Check if worktree already exists
    if git worktree list --porcelain | grep -qF "worktree $worktree_folder"; then
        echo "Worktree for '$branch' already exists at $worktree_folder"
        cd "$worktree_folder"
        return 0
    fi

    # Check if branch exists locally or on a remote
    if git show-ref --verify --quiet "refs/heads/$branch"; then
        echo "Branch '$branch' exists locally. Adding worktree..."
        git worktree add "$worktree_folder" "$branch" || return 1
    else
        # Fetch to ensure we have up-to-date remote refs
        git fetch --all --quiet
        local remote_ref
        remote_ref=$(git for-each-ref --format='%(refname:short)' "refs/remotes/*/$branch" | head -1)
        if [[ -n "$remote_ref" ]]; then
            echo "Branch '$branch' found on remote ($remote_ref). Adding worktree..."
            git worktree add --track -b "$branch" "$worktree_folder" "$remote_ref" || return 1
        else
            echo "Branch '$branch' does not exist locally or on any remote."
            local base_branch
            base_branch=$(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --short HEAD)
            vared -p "Create from which branch? [default: $base_branch] " base_branch
            echo "Creating branch '$branch' from '$base_branch' and adding worktree..."
            git worktree add -b "$branch" "$worktree_folder" "$base_branch" || return 1
        fi
    fi

    echo "Worktree created at $worktree_folder"

    # Copy project files
    echo "Copying project files..."
    pushd "$main_repo" > /dev/null
    [[ -f .idea/workspace.xml ]] && mkdir -p "$worktree_folder/.idea" && cp .idea/workspace.xml "$worktree_folder/.idea/workspace.xml" && echo "  - Copied .idea/workspace.xml"
    [[ -f secrets.properties ]] && cp secrets.properties "$worktree_folder/secrets.properties" && echo "  - Copied secrets.properties"
    find . -name "*.local*" -type f -exec gcp --parents -t "$worktree_folder" {} + 2>/dev/null && echo "  - Copied *.local* files"
    popd > /dev/null

    echo "Done. Switching to worktree..."
    cd "$worktree_folder"
}

_gwc() {
    local -a local_branches remote_branches
    local_branches=(${(f)"$(git branch --format='%(refname:short)' 2>/dev/null)"})
    # Remote branches stripped of remote prefix, excluding duplicates of local ones and HEAD
    remote_branches=(${(f)"$(git branch -r --format='%(refname:short)' 2>/dev/null | sed 's|^[^/]*/||' | grep -vxF HEAD | grep -vxF "${(F)local_branches}")"})
    _describe 'local branch' local_branches
    _describe 'remote branch' remote_branches
}
compdef _gwc gwc

